# ============================================================
# Medical RAG — Environment Configuration
# Copy to .env and fill in all values before running.
# ============================================================

# --- Core Services ---
ENVIRONMENT=development
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
# Leave empty — uses JWKS auth (ES256 keys)
SUPABASE_JWT_SECRET=

QDRANT_URL=https://your-cluster.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=medical_chunks_local

GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=384

# --- Hugging Face Cloud Embeddings (recommended for free tier) ---
# Get a free token at https://huggingface.co/settings/tokens
ENABLE_HUGGINGFACE_EMBEDDINGS=true
HUGGINGFACEHUB_API_TOKEN=hf_your-huggingface-token
HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Feature Flags ---
ENABLE_HYBRID_SEARCH=true
ENABLE_QUERY_REWRITE=true
ENABLE_LLM_RERANK=true
ENABLE_LONG_TERM_MEMORY=true
ENABLE_RATE_LIMITING=true
ENABLE_GUARDRAILS=true
ENABLE_OBSERVABILITY=true
ENABLE_RESPONSE_CACHE=true
ENABLE_LANGGRAPH=true
ENABLE_CROSS_SESSION_HISTORY=true
ENABLE_LOCAL_EMBEDDINGS=false
ENABLE_QDRANT_MEMORY=false

# --- Upstash Redis (rate limiting + response cache) ---
UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
RATE_LIMIT_PER_MINUTE=10
RESPONSE_CACHE_TTL_SECONDS=86400

# --- LLM ---
LLM_MODEL=groq/llama-3.3-70b-versatile
LLM_FALLBACK_MODEL=gemini/gemini-2.5-flash

# --- Retrieval ---
RETRIEVAL_TOP_K=10
FINAL_CONTEXT_K=5
CHUNK_SIZE_TOKENS=400
CHUNK_OVERLAP_TOKENS=60
SESSION_SIMILARITY_THRESHOLD=0.3

# --- Langfuse (observability) ---
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# --- CORS (comma-separated origins, or * for dev) ---
CORS_ORIGINS=*

# --- Admin (comma-separated Supabase user IDs) ---
ADMIN_USER_IDS=user-id-1,user-id-2
